{
  "version": "1.0",
  "mode": "multi-repo",
  "figma": {
    "credentials": {
      "source": "env",
      "envVar": "FIGMA_PAT"
    }
  },
  "submodules": {
    "front-app": {
      "enabled": true,
      "role": "app-host",
      "figmaFileId": "REPLACE_WITH_APP_FILE_ID",
      "submodulePath": "submodules/front-app"
    }
  }
}
