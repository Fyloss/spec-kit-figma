{
  "version": "1.0",
  "mode": "single-repo",
  "figma": {
    "apiBaseUrl": "https://api.figma.com/v1",
    "credentials": {
      "source": "env",
      "envVar": "FIGMA_PAT"
    }
  },
  "repo": {
    "enabled": true,
    "role": "app",
    "figmaFileId": "single123FILE",
    "submodulePath": ".",
    "designSystem": {
      "submodulePath": "src/design-system",
      "tokenSource": "src/design-system/tokens/**/*.json"
    }
  }
}
