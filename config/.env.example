# =============================================================================
# Figma credentials — LOCAL DEVELOPMENT ONLY
# =============================================================================
# Copy this file to ".env" at the workspace root and fill in your own token.
# The ".env" file MUST be git-ignored and MUST NEVER be committed.
#
# Generate a Personal Access Token at:
#   https://www.figma.com/developers/api#access-tokens
#
# Least privilege: grant READ-ONLY scopes only
#   - file_content:read
#   - file_metadata:read
#
# In CI / GitHub Cloud Agent contexts, do NOT use this file.
# Set credentials.source = "ci-secret" in figma.projects.config.json and inject
# the token through the platform secret store instead (see docs/CREDENTIALS.md).
# -----------------------------------------------------------------------------

FIGMA_PAT=figd_REPLACE_WITH_YOUR_PERSONAL_ACCESS_TOKEN
